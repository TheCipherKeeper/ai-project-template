# Модель: ollama или openai для любого OpenAI-совместимого API.
REVIEW_MODEL_PROVIDER=ollama
REVIEW_MODEL_BASE_URL=http://localhost:11434
REVIEW_MODEL_API_KEY=
REVIEW_MODEL_ID=<tool-capable-code-model>

# Отдельная учётная запись GitHub App или bot-пользователя.
REVIEW_GITHUB_API_URL=https://api.github.com
REVIEW_GITHUB_TOKEN=<github-review-token>
REVIEW_GITHUB_REPOSITORY=<owner/repository>
REVIEW_GITHUB_REVIEWER_LOGIN=<reviewer-login>

# Ограничения локального процесса.
REVIEW_REQUIRED_CHECKS=policy,lint,tests
REVIEW_MAX_FILE_BYTES=200000
REVIEW_MAX_DIFF_BYTES=500000
REVIEW_POLL_SECONDS=30
