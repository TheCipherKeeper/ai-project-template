{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "enum": [1, 2] },
    "task_id": { "$ref": "#/$defs/task_id" },
    "methodology_ref": { "$ref": "#/$defs/methodology_ref" },
    "deliveries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/delivery" }
    },
    "repository": { "$ref": "#/$defs/repository" },
    "run_id": { "$ref": "#/$defs/run_id" },
    "pr": { "$ref": "#/$defs/pr" },
    "commit": { "$ref": "#/$defs/commit" },
    "checks": { "$ref": "#/$defs/checks" },
    "reviews": { "$ref": "#/$defs/reviews" },
    "attempts": { "$ref": "#/$defs/attempts" },
    "artifact": { "$ref": "#/$defs/artifact" },
    "deployment": { "$ref": "#/$defs/deployment" },
    "status": { "$ref": "#/$defs/status" },
    "created_at": { "$ref": "#/$defs/date_time" },
    "retained_until": { "$ref": "#/$defs/date_time" }
  },
  "oneOf": [
    {
      "required": ["schema_version", "task_id", "repository", "run_id", "pr", "commit", "methodology_ref", "checks", "reviews", "attempts", "artifact", "deployment", "status", "created_at", "retained_until"],
      "properties": {
        "schema_version": { "const": 1 },
        "deliveries": false
      }
    },
    {
      "required": ["schema_version", "task_id", "methodology_ref", "deliveries", "status", "created_at", "retained_until"],
      "properties": {
        "schema_version": { "const": 2 },
        "repository": false,
        "run_id": false,
        "pr": false,
        "commit": false,
        "checks": false,
        "reviews": false,
        "attempts": false,
        "artifact": false,
        "deployment": false
      }
    }
  ],
  "$defs": {
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "run_id", "pr", "commit", "checks", "reviews", "attempts", "artifact", "deployment"],
      "properties": {
        "repository": { "$ref": "#/$defs/repository" },
        "run_id": { "$ref": "#/$defs/run_id" },
        "pr": { "$ref": "#/$defs/pr" },
        "commit": { "$ref": "#/$defs/commit" },
        "checks": { "$ref": "#/$defs/checks" },
        "reviews": { "$ref": "#/$defs/reviews" },
        "attempts": { "$ref": "#/$defs/attempts" },
        "artifact": { "$ref": "#/$defs/artifact" },
        "deployment": { "$ref": "#/$defs/deployment" }
      }
    },
    "task_id": { "type": "string", "pattern": "^TASK-[0-9]{4,}$" },
    "repository": { "type": "string", "pattern": "^https://[^/]+/.+/.+$" },
    "run_id": { "type": "string", "minLength": 1 },
    "pr": { "type": "string", "pattern": "^https://[^/]+/.+/pull/[0-9]+$" },
    "commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
    "methodology_ref": { "type": "string", "pattern": "^(?:[0-9a-f]{7,40}|v[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[0-9]+)?)$" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/result" }
    },
    "reviews": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/review" }
    },
    "attempts": { "type": "integer", "minimum": 1, "maximum": 3 },
    "artifact": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment", "probes"],
      "properties": {
        "environment": { "type": "string", "minLength": 1 },
        "probes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/result" }
        }
      }
    },
    "status": { "enum": ["passed", "failed", "held"] },
    "date_time": { "type": "string", "format": "date-time" },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "source"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["passed", "failed", "not_applicable"] },
        "source": { "type": "string", "pattern": "^https://[^/]+/.+" },
        "reviewer": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "not_applicable" } }, "required": ["status"] },
          "then": { "required": ["reason"] }
        }
      ]
    },
    "review": {
      "allOf": [
        { "$ref": "#/$defs/result" },
        { "required": ["reviewer"] }
      ]
    }
  }
}
