{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "run_id", "pr", "commit", "methodology_ref", "checks", "reviews", "attempts", "artifact", "deployment", "status", "created_at", "retained_until"],
  "properties": {
    "schema_version": { "const": 1 },
    "task_id": { "type": "string", "pattern": "^TASK-[0-9]{4,}$" },
    "run_id": { "type": "string", "minLength": 1 },
    "pr": { "type": "string", "pattern": "^https://[^/]+/.+/pull/[0-9]+$" },
    "commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
    "methodology_ref": { "type": "string", "pattern": "^(?:[0-9a-f]{7,40}|v[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[0-9]+)?)$" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/result" }
    },
    "reviews": {
      "type": "array",
      "items": { "$ref": "#/$defs/review" }
    },
    "attempts": { "type": "integer", "minimum": 1, "maximum": 3 },
    "artifact": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment", "probes"],
      "properties": {
        "environment": { "type": "string", "minLength": 1 },
        "probes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/result" }
        }
      }
    },
    "status": { "enum": ["passed", "failed", "held"] },
    "created_at": { "type": "string", "format": "date-time" },
    "retained_until": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "source"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["passed", "failed", "not_applicable"] },
        "source": { "type": "string", "minLength": 1 },
        "reviewer": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "not_applicable" } }, "required": ["status"] },
          "then": { "required": ["reason"] }
        }
      ]
    },
    "review": {
      "allOf": [
        { "$ref": "#/$defs/result" },
        { "required": ["reviewer"] }
      ]
    }
  }
}
