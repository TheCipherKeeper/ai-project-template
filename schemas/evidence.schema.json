{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["task_id", "run_id", "commit", "methodology", "artifact", "status", "created_at"],
  "properties": {
    "task_id": { "pattern": "^TASK-[0-9]{4,}$" },
    "run_id": { "type": "string", "minLength": 1 },
    "commit": { "pattern": "^[0-9a-f]{7,40}$" },
    "methodology": { "type": "string", "minLength": 1 },
    "artifact": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed", "held", "not_applicable"] },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
