{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/methodology.schema.json",
  "type": "object",
  "required": ["schema_version", "repository_type", "methodology_ref"],
  "properties": {
    "schema_version": { "const": 1 },
    "repository_type": { "enum": ["methodology", "hub", "service", "interface", "standalone"] },
    "methodology_ref": {
      "type": "string",
      "pattern": "^(self|[0-9a-f]{7,40}|v[0-9]+\\.[0-9]+\\.[0-9]+(-rc\\.[0-9]+)?)$"
    },
    "service_name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "service_language": { "enum": ["python", "go", "rust"] },
    "service_modules": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(,[a-z][a-z0-9_]*)*$"
    }
  },
  "allOf": [{
    "if": { "properties": { "repository_type": { "const": "service" } } },
    "then": { "required": ["service_name", "service_language", "service_modules"] }
  }],
  "additionalProperties": false
}
