{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/methodology.schema.json",
  "type": "object",
  "required": ["schema_version", "repository_type", "methodology", "verification"],
  "properties": {
    "schema_version": { "const": 1 },
    "repository_type": { "enum": ["methodology", "hub", "service", "interface", "standalone"] },
    "methodology": {
      "type": "object",
      "required": ["repository", "version"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$" }
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": ["policy", "fail_on_agent_unavailable"],
      "properties": {
        "policy": { "const": "strict" },
        "fail_on_agent_unavailable": { "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
