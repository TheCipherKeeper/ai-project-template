{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "status", "target", "risk", "autonomy", "goal", "acceptance_criteria", "rollback"],
  "properties": {
    "id": { "pattern": "^TASK-[0-9]{4,}$" },
    "status": { "enum": ["ready", "in_progress", "done", "needs-spec", "needs-architecture", "needs-access", "blocked-external", "automation-failed", "retry-exhausted"] },
    "target": { "type": "string", "minLength": 1 },
    "risk": { "enum": ["low", "medium", "high", "critical"] },
    "autonomy": { "enum": ["pr-only", "human-before-merge", "auto-test-deploy", "human-before-production"] },
    "goal": { "type": "string", "minLength": 1 },
    "acceptance_criteria": { "type": "array", "minItems": 1 },
    "rollback": { "type": "string", "minLength": 1 }
  }
}
