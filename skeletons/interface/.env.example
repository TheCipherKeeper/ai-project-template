# Шаблон переменных окружения. Копируй в .env и заполняй.
# .env не коммитится (см. .gitignore); этот файл — единственный источник имён ключей.
# URL presentation-эндпоинтов gateway-сервиса (interface — клиент на границе,
# потребляет только gateway; один URL/CORS/auth).

# gateway-сервис (единственный browser-facing surface)
VITE_API_GATEWAY=https://<host>/v1