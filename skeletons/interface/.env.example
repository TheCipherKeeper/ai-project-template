# Шаблон переменных окружения. Копируй в .env и заполняй.
# .env не коммитится (см. .gitignore); этот файл — единственный источник имён ключей.
# URL presentation-эндпоинтов сервисов (interface — клиент на границе, не брокер-клиент).

# Сервис A
VITE_API_SERVICE_A=https://<host>/v1
# Сервис B
VITE_API_SERVICE_B=https://<host>/v1