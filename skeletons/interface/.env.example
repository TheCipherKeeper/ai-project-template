# Шаблон переменных окружения. Копируй в .env и заполняй.
# .env не коммитится (см. .gitignore); этот файл — единственный источник имён ключей.
# URL клиентского API сервиса-шлюза: интерфейс потребляет только его; используются
# единые адрес, политика CORS и аутентификация.

# сервис-шлюз (клиентский API для интерфейсов)
VITE_API_GATEWAY=https://<host>/v1
