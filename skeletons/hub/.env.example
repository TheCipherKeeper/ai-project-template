# Шаблон переменных окружения системного файла Docker Compose хаба. Копируй в .env и заполняй.
# .env не коммитится (см. .gitignore); этот файл — единственный источник имён ключей.
# Применяется к сервисам в системном файле Docker Compose через `env_file: .env`.

# Брокер (адрес внутри сети Docker Compose — общий для всех сервисов)
BROKER_ADDR=broker:9092

# Per-сервис конфиг (примеры; на сервис — свой набор).
# <SERVICE-A>_LOG_LEVEL=info
# <SERVICE-A>_<KEY>=...
# <SERVICE-B>_LOG_LEVEL=info
