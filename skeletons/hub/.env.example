# Шаблон переменных окружения системного compose хаба. Копируй в .env и заполняй.
# .env не коммитится (см. .gitignore); этот файл — единственный источник имён ключей.
# Применяется к сервисам в системном compose через env_file: .env.

# Брокер (адрес внутри сети compose — общий для всех сервисов)
BROKER_ADDR=broker:9092

# Пин контракта, на котором работает программа (хаб поддерживает).
CONVENTIONS_PIN=v1

# Per-сервис конфиг (примеры; на сервис — свой набор).
# <SERVICE-A>_LOG_LEVEL=info
# <SERVICE-A>_<KEY>=...
# <SERVICE-B>_LOG_LEVEL=info