# Шаблон переменных окружения автономного компонента. Скопируйте в .env и заполните.
# .env не коммитится (см. .gitignore); этот файл — единственный источник имён ключей.
# Брокера НЕТ — автономный компонент не участник брокера и не зовёт чужие сервисы.
# Значения задаются средой развёртывания; здесь фиксируются только имена ключей.

# Идентичность и размещение компонента
<COMPONENT>_INSTANCE_ID=<id>      # идентификатор экземпляра
<COMPONENT>_BIND_IP=0.0.0.0       # на каком IP слушать поверхности
<COMPONENT>_LOG_LEVEL=info

# Поверхности (примеры; у компонента свой набор портов/баннеров)
# <COMPONENT>_PORT_<N>=...
# <COMPONENT>_BANNER_<PROTO>=...
