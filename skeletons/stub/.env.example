# Шаблон переменных окружения автономного компонента. Скопируйте в .env и заполните.
# .env не коммитится (см. .gitignore); этот файл — единственный источник имён ключей.
# Брокера НЕТ — stub не участник брокера и не зовёт чужие сервисы.
# Параметры автономного компонента задаются его дескриптором;

# Идентичность и размещение цели
<STUB>_TARGET_ID=<id>             # какой сервис изображает (из дескриптора)
<STUB>_BIND_IP=0.0.0.0            # на каком IP слушать поверхности
<STUB>_LOG_LEVEL=info

# Поверхности (примеры; на stub — свой набор портов/баннеров)
# <STUB>_PORT_<N>=...
# <STUB>_BANNER_<PROTO>=...
