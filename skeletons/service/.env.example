# Шаблон переменных окружения. Копируй в .env и заполняй.
# .env не коммитится (см. .gitignore); этот файл — единственный источник имён ключей.

# Брокер (адрес для сервисов внутри сети Docker Compose)
BROKER_ADDR=broker:9092

# Периметр сервиса (пример). На сервис — свой набор переменных.
# <SERVICE-A>_NODE_ID=...
# <SERVICE-A>_LOG_LEVEL=info
