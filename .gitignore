# Артефакты сборки/кэш — дополни под выбранный стек. Один сервис = один стек.

# --- Rust ---
/target/
**/*.rs.bk
Cargo.lock  # раскомментируй СТРОКОЙ ВЫШЕ для бинарника; для библиотеки коммитят

# --- Go ---
/bin/
*.exe
*.test
*.out

# --- Python ---
__pycache__/
*.pyc
.venv/
.venv*/
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- Node/TypeScript ---
node_modules/
dist/
*.tsbuildinfo
.turbo/
.vite/

# --- IDE / ОС ---
.idea/
.vscode/
.DS_Store
Thumbs.db

# --- Локальные секреты и конфиги окружения ---
*.local
.env
.env.*
config/local.*