# Артефакты сборки/кэш — дополни под выбранные стеки. Один сервис = один стек.

# --- Rust ---
/target/
**/*.rs.bk

# --- Go ---
/bin/
*.exe
*.test
*.out

# --- Python ---
__pycache__/
*.pyc
.venv/
.venv*/
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- Node/TypeScript ---
node_modules/
dist/
*.tsbuildinfo
.turbo/
.vite/

# --- Docker ---
# локальные переопределения compose (не коммитим)
docker-compose.override.yml

# --- IDE / ОС ---
.idea/
.vscode/
.DS_Store
Thumbs.db

# --- Локальные секреты и конфиги окружения ---
*.local
.env
.env.*
!.env.example
config/local.*

# Локальные отчёты; CI хранит их как evidence artifacts
verification.json
.evidence/*
!.evidence/README.md
